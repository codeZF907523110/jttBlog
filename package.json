{
  "name": "jtt-blog",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "lint": "eslint . --ext .ts,.cjs,.js,.mjs --no-ignore",
    "lint:fix": "eslint . --ext .ts,.cjs,.js,.mjs --no-ignore --fix",
    "format": "prettier --write .",
    "prepare": "husky",
    "build": "vitepress build docs",
    "dev": "vitepress dev docs"
  },
  "lint-staged": {
    "*.{ts,js,cjs,mjs,vue}": [
      "eslint --fix --no-ignore",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^19.7.1",
    "@commitlint/config-conventional": "^19.7.1",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3",
    "vitepress": "^1.6.3",
    "vue": "^3.5.13"
  },
  "dependencies": {
    "vue-seasons-falling": "^0.2.3"
  }
}
